@if (Award is not null)
{
    <div class="card h-100 border-warning text-center shadow-sm">
        <div class="card-body p-3">
            <div class="display-4 mb-2">🏅</div>
            <h6 class="card-title fw-bold mb-1">@Award.BadgeName</h6>
            @if (!string.IsNullOrWhiteSpace(Award.BadgeDescription))
            {
                <p class="card-text text-muted small mb-2">@Award.BadgeDescription</p>
            }
            @if (Award.ThresholdKm > 0)
            {
                <span class="badge bg-warning text-dark mb-2">@Award.ThresholdKm km</span>
            }
            <div class="text-muted small">
                Earned @Award.AwardedAt.ToString("MMM d, yyyy")
            </div>
            @if (Award.IsManual)
            {
                <div class="text-muted small fst-italic">Honorary</div>
            }
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public BadgeAwardDto? Award { get; set; }
}

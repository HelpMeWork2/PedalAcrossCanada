@if (_toasts.Count > 0)
{
    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1080;">
        @foreach (var toast in _toasts)
        {
            <div class="toast show @(toast.IsError ? "bg-danger" : "bg-success") text-white"
                 role="alert" aria-live="assertive" aria-atomic="true">
                <div class="toast-header">
                    <strong class="me-auto">@(toast.IsError ? "Error" : "Success")</strong>
                    <button type="button" class="btn-close btn-close-white"
                            @onclick="() => Dismiss(toast)"></button>
                </div>
                <div class="toast-body">@toast.Message</div>
            </div>
        }
    </div>
}

@code {
    private readonly List<ToastItem> _toasts = [];

    public void ShowSuccess(string message)
    {
        Show(message, isError: false);
    }

    public void ShowError(string message)
    {
        Show(message, isError: true);
    }

    private void Show(string message, bool isError)
    {
        var item = new ToastItem(message, isError);
        _toasts.Add(item);
        StateHasChanged();

        _ = DismissAfterDelay(item);
    }

    private async Task DismissAfterDelay(ToastItem item)
    {
        await Task.Delay(5000);
        Dismiss(item);
    }

    private void Dismiss(ToastItem item)
    {
        _toasts.Remove(item);
        StateHasChanged();
    }

    private record ToastItem(string Message, bool IsError);
}

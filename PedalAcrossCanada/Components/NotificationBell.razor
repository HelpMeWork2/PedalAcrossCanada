@implements IDisposable
@inject NotificationHttpService NotificationService

<div class="notification-bell-wrapper position-relative d-inline-block me-3">
    <button class="btn btn-link text-dark p-0 position-relative"
            @onclick="ToggleDropdownAsync"
            title="Notifications"
            aria-label="Notifications">
        <span class="fs-5">🔔</span>
        @if (_unreadCount > 0)
        {
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                  style="font-size:0.6rem">
                @(_unreadCount > 99 ? "99+" : _unreadCount.ToString())
            </span>
        }
    </button>

    @if (_dropdownOpen)
    {
        <div class="dropdown-menu dropdown-menu-end show notification-dropdown shadow"
             style="min-width:320px;max-height:400px;overflow-y:auto;">
            <div class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom">
                <span class="fw-semibold small">Notifications</span>
                @if (_unreadCount > 0)
                {
                    <button class="btn btn-link btn-sm p-0 text-primary small" @onclick="MarkAllReadAsync">
                        Mark all read
                    </button>
                }
            </div>
            <NotificationList @ref="_notificationList" />
        </div>
    }
</div>

@code {
    private int _unreadCount;
    private bool _dropdownOpen;
    private NotificationList? _notificationList;
    private Timer? _pollTimer;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await RefreshUnreadCountAsync();
            _pollTimer = new Timer(async _ =>
            {
                await RefreshUnreadCountAsync();
                await InvokeAsync(StateHasChanged);
            }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
        }
    }

    private async Task RefreshUnreadCountAsync()
    {
        try
        {
            var result = await NotificationService.GetUnreadCountAsync();
            _unreadCount = result?.Count ?? 0;
        }
        catch
        {
            // silently ignore polling failures
        }
    }

    private async Task ToggleDropdownAsync()
    {
        _dropdownOpen = !_dropdownOpen;

        if (_dropdownOpen && _unreadCount > 0)
        {
            // Reset count optimistically; list will show current state
            _unreadCount = 0;
            await NotificationService.MarkAllAsReadAsync();
        }
    }

    private async Task MarkAllReadAsync()
    {
        _unreadCount = 0;
        await NotificationService.MarkAllAsReadAsync();
        StateHasChanged();
    }

    public void Dispose()
    {
        _pollTimer?.Dispose();
    }
}

@page "/admin/audit"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@inject AuditHttpService AuditService

<PageTitle>Audit Log - Pedal Across Canada</PageTitle>

<h3 class="mb-4">Audit Log</h3>

<Toast @ref="_toast" />

<div class="card mb-4">
    <div class="card-body">
        <h6 class="card-title mb-3">Filter</h6>
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Entity Type</label>
                <select class="form-select" @bind="_filterEntityType">
                    <option value="">All</option>
                    <option value="Event">Event</option>
                    <option value="Milestone">Milestone</option>
                    <option value="Participant">Participant</option>
                    <option value="Activity">Activity</option>
                    <option value="Team">Team</option>
                    <option value="Badge">Badge</option>
                    <option value="BadgeAward">BadgeAward</option>
                    <option value="ExternalConnection">ExternalConnection</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Entity ID</label>
                <input class="form-control" placeholder="GUID" @bind="_filterEntityId" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Actor</label>
                <input class="form-control" placeholder="User ID" @bind="_filterActor" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Start Date</label>
                <input type="date" class="form-control" @bind="_filterStartDate" />
            </div>
            <div class="col-md-3">
                <label class="form-label">End Date</label>
                <input type="date" class="form-control" @bind="_filterEndDate" />
            </div>
            <div class="col-md-3 d-flex align-items-end gap-2">
                <button class="btn btn-primary" @onclick="ApplyFiltersAsync">Apply</button>
                <button class="btn btn-outline-secondary" @onclick="ClearFiltersAsync">Clear</button>
            </div>
        </div>
    </div>
</div>

@if (_isLoading)
{
    <LoadingSpinner Message="Loading audit log..." />
}
else if (_result is null || _result.TotalCount == 0)
{
    <div class="alert alert-info">No audit log entries match the current filters.</div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-2">
        <small class="text-muted">Showing @_result.Data.Count of @_result.TotalCount entries</small>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle small">
            <thead class="table-light">
                <tr>
                    <th>Timestamp (UTC)</th>
                    <th>Actor</th>
                    <th>Action</th>
                    <th>Entity Type</th>
                    <th>Entity ID</th>
                    <th class="text-center">Details</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var entry in _result.Data)
                {
                    <tr>
                        <td class="text-nowrap">@entry.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td class="font-monospace small">@TruncateId(entry.Actor)</td>
                        <td><span class="badge @GetActionBadgeClass(entry.Action)">@entry.Action</span></td>
                        <td>@entry.EntityType</td>
                        <td class="font-monospace small">@TruncateId(entry.EntityId)</td>
                        <td class="text-center">
                            @if (entry.BeforeSummary is not null || entry.AfterSummary is not null)
                            {
                                <button class="btn btn-outline-secondary btn-sm"
                                        @onclick="() => ToggleExpand(entry.Id)">
                                    @(_expandedId == entry.Id ? "▲ Hide" : "▼ Show")
                                </button>
                            }
                        </td>
                    </tr>
                    @if (_expandedId == entry.Id)
                    {
                        <tr class="table-secondary">
                            <td colspan="6">
                                <div class="row g-3 p-2">
                                    @if (entry.BeforeSummary is not null)
                                    {
                                        <div class="col-md-6">
                                            <strong class="text-danger">Before</strong>
                                            <pre class="bg-light border rounded p-2 small mt-1" style="max-height:200px;overflow:auto;">@entry.BeforeSummary</pre>
                                        </div>
                                    }
                                    @if (entry.AfterSummary is not null)
                                    {
                                        <div class="col-md-6">
                                            <strong class="text-success">After</strong>
                                            <pre class="bg-light border rounded p-2 small mt-1" style="max-height:200px;overflow:auto;">@entry.AfterSummary</pre>
                                        </div>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (_result.TotalPages > 1)
    {
        <nav>
            <ul class="pagination pagination-sm justify-content-center">
                <li class="page-item @(_result.HasPreviousPage ? "" : "disabled")">
                    <button class="page-link" @onclick="PreviousPageAsync">«</button>
                </li>
                @for (var p = Math.Max(1, _currentPage - 2); p <= Math.Min(_result.TotalPages, _currentPage + 2); p++)
                {
                    var pageNum = p;
                    <li class="page-item @(pageNum == _currentPage ? "active" : "")">
                        <button class="page-link" @onclick="() => GoToPageAsync(pageNum)">@pageNum</button>
                    </li>
                }
                <li class="page-item @(_result.HasNextPage ? "" : "disabled")">
                    <button class="page-link" @onclick="NextPageAsync">»</button>
                </li>
            </ul>
        </nav>
    }
}

@code {
    private Toast _toast = default!;
    private PedalAcrossCanada.Shared.Common.PagedResult<PedalAcrossCanada.Shared.DTOs.Audit.AuditLogDto>? _result;
    private bool _isLoading;
    private int _currentPage = 1;
    private const int PageSize = 25;

    private string? _filterEntityType;
    private string? _filterEntityId;
    private string? _filterActor;
    private DateTime? _filterStartDate;
    private DateTime? _filterEndDate;

    private Guid? _expandedId;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _isLoading = true;
        try
        {
            _result = await AuditService.GetAuditLogAsync(
                entityType: string.IsNullOrWhiteSpace(_filterEntityType) ? null : _filterEntityType,
                entityId: string.IsNullOrWhiteSpace(_filterEntityId) ? null : _filterEntityId,
                actor: string.IsNullOrWhiteSpace(_filterActor) ? null : _filterActor,
                startDate: _filterStartDate,
                endDate: _filterEndDate,
                page: _currentPage,
                pageSize: PageSize);
        }
        catch (HttpRequestException)
        {
            _toast.ShowError("Failed to load audit log.");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ApplyFiltersAsync()
    {
        _currentPage = 1;
        _expandedId = null;
        await LoadAsync();
    }

    private async Task ClearFiltersAsync()
    {
        _filterEntityType = null;
        _filterEntityId = null;
        _filterActor = null;
        _filterStartDate = null;
        _filterEndDate = null;
        _currentPage = 1;
        _expandedId = null;
        await LoadAsync();
    }

    private async Task PreviousPageAsync()
    {
        if (_currentPage > 1)
        {
            _currentPage--;
            await LoadAsync();
        }
    }

    private async Task NextPageAsync()
    {
        if (_result?.HasNextPage == true)
        {
            _currentPage++;
            await LoadAsync();
        }
    }

    private async Task GoToPageAsync(int page)
    {
        _currentPage = page;
        await LoadAsync();
    }

    private void ToggleExpand(Guid id)
    {
        _expandedId = _expandedId == id ? null : id;
    }

    private static string TruncateId(string id) =>
        id.Length > 16 ? id[..16] + "…" : id;

    private static string GetActionBadgeClass(string action) => action switch
    {
        var a when a.StartsWith("Create") => "bg-success",
        var a when a.StartsWith("Update") || a.StartsWith("Edit") => "bg-warning text-dark",
        var a when a.StartsWith("Delete") => "bg-danger",
        var a when a.StartsWith("Approve") => "bg-primary",
        var a when a.StartsWith("Reject") => "bg-danger",
        _ => "bg-secondary"
    };
}

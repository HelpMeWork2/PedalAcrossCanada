@page "/milestones"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject EventHttpService EventService
@inject MilestoneHttpService MilestoneService

<PageTitle>Milestones - Pedal Across Canada</PageTitle>

<h3 class="mb-4">Route Milestones</h3>

<Toast @ref="_toast" />

@if (_isLoading)
{
    <LoadingSpinner Message="Loading milestones..." />
}
else if (_event is null)
{
    <div class="alert alert-info">No active event at this time.</div>
}
else
{
    <EventStatusBanner Event="_event" />

    @if (_milestones.Count == 0)
    {
        <div class="alert alert-info">No milestones have been defined for this event yet.</div>
    }
    else
    {
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title">Route Progress</h5>
                <div class="progress" style="height: 30px;">
                    <div class="progress-bar bg-success progress-bar-striped progress-bar-animated"
                         role="progressbar"
                         style="width: @ProgressPercent%;"
                         aria-valuenow="@ProgressPercent"
                         aria-valuemin="0"
                         aria-valuemax="100">
                        @ProgressPercent.ToString("N1")%
                    </div>
                </div>
                <div class="d-flex justify-content-between mt-1 small text-muted">
                    <span>Montreal</span>
                    @if (_nextMilestone is not null)
                    {
                        <span>Next: @_nextMilestone.StopName (@_nextMilestone.CumulativeDistanceKm.ToString("N0") km)</span>
                    }
                    <span>Calgary (@_event.RouteDistanceKm.ToString("N0") km)</span>
                </div>
            </div>
        </div>

        <div class="timeline">
            @foreach (var m in _milestones)
            {
                var isAchieved = m.AchievedAt.HasValue;
                var isNext = !isAchieved && (_nextMilestone?.Id == m.Id);

                <div class="card mb-3 @(isAchieved ? "border-success" : isNext ? "border-primary" : "")">
                    <div class="card-body d-flex align-items-start">
                        <div class="me-3 text-center" style="min-width: 60px;">
                            @if (isAchieved)
                            {
                                <span class="badge bg-success rounded-pill fs-6">✓</span>
                            }
                            else if (isNext)
                            {
                                <span class="badge bg-primary rounded-pill fs-6">→</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary rounded-pill fs-6">@m.OrderIndex</span>
                            }
                            <div class="small text-muted mt-1">@m.CumulativeDistanceKm.ToString("N0") km</div>
                        </div>
                        <div class="flex-grow-1">
                            <h6 class="mb-1">
                                @m.StopName
                                @if (isAchieved)
                                {
                                    <small class="text-success ms-2">
                                        Achieved @m.AchievedAt!.Value.ToString("MMM d, yyyy")
                                    </small>
                                }
                            </h6>
                            @if (!string.IsNullOrEmpty(m.Description))
                            {
                                <p class="mb-1 text-muted">@m.Description</p>
                            }
                            @if (!string.IsNullOrEmpty(m.RewardText) && isAchieved)
                            {
                                <span class="badge bg-warning text-dark">🎉 @m.RewardText</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

@code {
    private PedalAcrossCanada.Shared.DTOs.Events.EventDto? _event;
    private List<PedalAcrossCanada.Shared.DTOs.Milestones.MilestoneDto> _milestones = [];
    private PedalAcrossCanada.Shared.DTOs.Milestones.MilestoneDto? _nextMilestone;
    private bool _isLoading = true;
    private Toast _toast = null!;

    private decimal ProgressPercent
    {
        get
        {
            if (_event is null || _event.RouteDistanceKm == 0) return 0;
            var lastAchieved = _milestones
                .Where(m => m.AchievedAt.HasValue)
                .OrderByDescending(m => m.CumulativeDistanceKm)
                .FirstOrDefault();
            if (lastAchieved is null) return 0;
            var pct = (lastAchieved.TotalKmAtAchievement ?? lastAchieved.CumulativeDistanceKm)
                      / _event.RouteDistanceKm * 100m;
            return Math.Min(pct, 100m);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        try
        {
            _event = await EventService.GetActiveEventAsync();
            if (_event is not null)
            {
                var milestones = await MilestoneService.GetAllAsync(_event.Id);
                _milestones = milestones?.ToList() ?? [];
                _nextMilestone = _milestones
                    .Where(m => !m.AchievedAt.HasValue)
                    .OrderBy(m => m.OrderIndex)
                    .FirstOrDefault();
            }
        }
        catch (HttpRequestException)
        {
            _toast.ShowError("Failed to load milestone data.");
        }
        finally
        {
            _isLoading = false;
        }
    }
}

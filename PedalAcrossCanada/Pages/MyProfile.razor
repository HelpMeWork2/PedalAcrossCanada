@page "/profile"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject EventHttpService EventService
@inject ParticipantHttpService ParticipantService
@inject StravaHttpService StravaService
@inject NavigationManager Navigation

<PageTitle>My Profile - Pedal Across Canada</PageTitle>

<h3 class="mb-4">My Profile</h3>

<Toast @ref="_toast" />

@if (_isLoading)
{
    <LoadingSpinner Message="Loading profile..." />
}
else if (_event is null)
{
    <div class="alert alert-info">
        There is no active event at this time.
    </div>
}
else if (_participant is null)
{
    <div class="alert alert-warning">
        You are not registered for the current event.
        <button class="btn btn-success btn-sm ms-3" @onclick="NavigateToJoin">Join Now</button>
    </div>
}
else
{
    <EventStatusBanner Event="_event" />

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-body p-4">
                    @if (!_isEditing)
                    {
                        <dl class="row mb-0">
                            <dt class="col-sm-4">Display Name</dt>
                            <dd class="col-sm-8">@_participant.DisplayName</dd>

                            <dt class="col-sm-4">Name</dt>
                            <dd class="col-sm-8">@_participant.FirstName @_participant.LastName</dd>

                            <dt class="col-sm-4">Email</dt>
                            <dd class="col-sm-8">@_participant.WorkEmail</dd>

                            <dt class="col-sm-4">Team</dt>
                            <dd class="col-sm-8">@(_participant.TeamName ?? "None")</dd>

                            <dt class="col-sm-4">Status</dt>
                            <dd class="col-sm-8">
                                <span class="badge @(_participant.Status == ParticipantStatus.Active ? "bg-success" : "bg-secondary")">
                                    @_participant.Status
                                </span>
                            </dd>

                            <dt class="col-sm-4">Joined</dt>
                            <dd class="col-sm-8">@_participant.JoinedAt.ToString("MMM d, yyyy")</dd>

                            <dt class="col-sm-4">Leaderboard</dt>
                            <dd class="col-sm-8">@(_participant.LeaderboardOptIn ? "Opted In" : "Opted Out")</dd>
                        </dl>

                        <button class="btn btn-primary mt-3" @onclick="StartEditing">Edit Profile</button>
                    }
                    else
                    {
                        <EditForm Model="_formModel" OnValidSubmit="HandleUpdateAsync">
                            <DataAnnotationsValidator />

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label">First Name</label>
                                    <InputText class="form-control" @bind-Value="_formModel.FirstName" />
                                    <ValidationMessage For="() => _formModel.FirstName" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Last Name</label>
                                    <InputText class="form-control" @bind-Value="_formModel.LastName" />
                                    <ValidationMessage For="() => _formModel.LastName" />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Display Name</label>
                                <InputText class="form-control" @bind-Value="_formModel.DisplayName" />
                                <ValidationMessage For="() => _formModel.DisplayName" />
                            </div>

                            <div class="form-check mb-3">
                                <InputCheckbox class="form-check-input" @bind-Value="_formModel.LeaderboardOptIn" />
                                <label class="form-check-label">Show me on leaderboards</label>
                            </div>

                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-success" disabled="@_isSaving">
                                    @if (_isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                    Save
                                </button>
                                <button type="button" class="btn btn-secondary" @onclick="CancelEditing">Cancel</button>
                            </div>
                        </EditForm>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-activity"></i> Strava</h5>
                </div>
                <div class="card-body">
                    @if (_isLoadingStrava)
                    {
                        <LoadingSpinner Message="Loading Strava status..." />
                    }
                    else if (_stravaStatus is not null && _stravaStatus.IsConnected)
                    {
                        <div class="mb-3">
                            <span class="badge bg-success">Connected</span>
                            @if (!string.IsNullOrEmpty(_stravaStatus.ExternalAthleteId))
                            {
                                <span class="text-muted ms-2">Athlete @_stravaStatus.ExternalAthleteId</span>
                            }
                        </div>
                        @if (_stravaStatus.LastSyncAt.HasValue)
                        {
                            <p class="text-muted small mb-3">
                                Last synced: @_stravaStatus.LastSyncAt.Value.ToString("MMM d, yyyy h:mm tt")
                            </p>
                        }
                        <div class="d-flex gap-2">
                            <button class="btn btn-outline-primary btn-sm" @onclick="HandleSyncAsync" disabled="@_isSyncing">
                                @if (_isSyncing) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Sync Now
                            </button>
                            <button class="btn btn-outline-danger btn-sm" @onclick="HandleDisconnectAsync" disabled="@_isSyncing">
                                Disconnect
                            </button>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-3">Connect your Strava account to automatically import rides.</p>
                        <button class="btn btn-warning" @onclick="HandleConnectStravaAsync" disabled="@_isConnectingStrava">
                            @if (_isConnectingStrava) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            <img src="https://cdn.worldvectorlogo.com/logos/strava-2.svg" alt="Strava" style="height: 20px;" class="me-1" />
                            Connect with Strava
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private EventDto? _event;
    private ParticipantDto? _participant;
    private bool _isLoading = true;
    private bool _isEditing;
    private bool _isSaving;
    private ProfileFormModel _formModel = new();
    private Toast _toast = null!;

    // Strava state
    private StravaStatusDto? _stravaStatus;
    private bool _isLoadingStrava;
    private bool _isConnectingStrava;
    private bool _isSyncing;

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        try
        {
            _event = await EventService.GetActiveEventAsync();
            if (_event is not null)
            {
                try
                {
                    _participant = await ParticipantService.GetMeAsync(_event.Id);
                }
                catch (HttpRequestException)
                {
                    _participant = null;
                }
            }
        }
        catch (HttpRequestException)
        {
            _toast.ShowError("Failed to load profile.");
        }
        finally
        {
            _isLoading = false;
        }

        if (_event is not null && _participant is not null)
        {
            await LoadStravaStatusAsync();
        }
    }

    private async Task LoadStravaStatusAsync()
    {
        _isLoadingStrava = true;
        try
        {
            _stravaStatus = await StravaService.GetStatusAsync(_event!.Id);
        }
        catch (HttpRequestException)
        {
            // Strava status not available - leave as null
        }
        finally
        {
            _isLoadingStrava = false;
        }
    }

    private async Task HandleConnectStravaAsync()
    {
        if (_event is null) return;

        _isConnectingStrava = true;
        try
        {
            var authUrl = await StravaService.GetAuthUrlAsync(_event.Id);
            if (authUrl is not null)
            {
                Navigation.NavigateTo(authUrl.AuthorizationUrl, forceLoad: true);
            }
        }
        catch (HttpRequestException ex)
        {
            _toast.ShowError($"Failed to start Strava connection: {ex.Message}");
            _isConnectingStrava = false;
        }
    }

    private async Task HandleSyncAsync()
    {
        if (_event is null) return;

        _isSyncing = true;
        try
        {
            var result = await StravaService.ManualSyncAsync(_event.Id);
            if (result is not null)
            {
                if (!string.IsNullOrEmpty(result.ErrorMessage))
                {
                    _toast.ShowError(result.ErrorMessage);
                }
                else
                {
                    _toast.ShowSuccess($"Sync complete: {result.ImportedCount} imported, {result.SkippedDuplicateCount} skipped.");
                }
            }
            await LoadStravaStatusAsync();
        }
        catch (HttpRequestException ex)
        {
            _toast.ShowError($"Sync failed: {ex.Message}");
        }
        finally
        {
            _isSyncing = false;
        }
    }

    private async Task HandleDisconnectAsync()
    {
        if (_event is null) return;

        _isSyncing = true;
        try
        {
            await StravaService.DisconnectAsync(_event.Id);
            _stravaStatus = null;
            _toast.ShowSuccess("Strava disconnected.");
        }
        catch (HttpRequestException ex)
        {
            _toast.ShowError($"Disconnect failed: {ex.Message}");
        }
        finally
        {
            _isSyncing = false;
        }
    }

    private void StartEditing()
    {
        if (_participant is null) return;
        _formModel = new ProfileFormModel
        {
            FirstName = _participant.FirstName,
            LastName = _participant.LastName,
            DisplayName = _participant.DisplayName,
            LeaderboardOptIn = _participant.LeaderboardOptIn
        };
        _isEditing = true;
    }

    private void CancelEditing() => _isEditing = false;

    private async Task HandleUpdateAsync()
    {
        if (_event is null || _participant is null) return;

        _isSaving = true;
        try
        {
            var request = new UpdateParticipantRequest
            {
                FirstName = _formModel.FirstName,
                LastName = _formModel.LastName,
                DisplayName = _formModel.DisplayName,
                LeaderboardOptIn = _formModel.LeaderboardOptIn
            };

            _participant = await ParticipantService.UpdateAsync(_event.Id, _participant.Id, request);
            _toast.ShowSuccess("Profile updated.");
            _isEditing = false;
        }
        catch (HttpRequestException ex)
        {
            _toast.ShowError($"Update failed: {ex.Message}");
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void NavigateToJoin() => Navigation.NavigateTo("/join");

    private class ProfileFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MaxLength(100)]
        public string FirstName { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MaxLength(100)]
        public string LastName { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MaxLength(100)]
        public string DisplayName { get; set; } = string.Empty;

        public bool LeaderboardOptIn { get; set; } = true;
    }
}

@inherits LayoutComponentBase
@inject AuthHttpService AuthService
@inject NavigationManager Navigation
<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex align-items-center justify-content-end gap-2">
            <AuthorizeView>
                <Authorized>
                    <NotificationBell />
                    <button class="btn btn-sm btn-outline-danger" @onclick="LogoutAsync" title="Sign out">
                        ⏻ Sign out
                    </button>
                </Authorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login");
    }
}
